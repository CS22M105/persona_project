APP_ENV=local
APP_NAME=AI Patient Voice Backend
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql+psycopg://persona:persona@localhost:5432/persona_project
OPENAI_API_KEY=replace_later
